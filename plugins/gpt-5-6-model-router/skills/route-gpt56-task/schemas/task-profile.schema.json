{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://paxdynamics.com/schemas/gpt56-router/task-profile-v3.json",
  "title": "GPT-5.6 Router Input v3",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "kind", "ambiguity", "context_breadth", "verification_strength", "risk_domains"],
  "properties": {
    "schema_version": {"const": 3},
    "kind": {"enum": ["mechanical", "exploration", "implementation", "ambiguous", "debugging", "review", "advisory"]},
    "ambiguity": {"type": "integer", "minimum": 0, "maximum": 3},
    "context_breadth": {"type": "integer", "minimum": 0, "maximum": 3},
    "verification_strength": {"type": "integer", "minimum": 0, "maximum": 3},
    "risk_domains": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "quality_first": {"type": "boolean", "default": false},
    "prior_route_failure": {
      "type": "object",
      "additionalProperties": false,
      "required": ["model", "effort", "evidence"],
      "properties": {
        "agent": {"type": "string", "minLength": 1},
        "model": {"type": "string", "minLength": 1},
        "effort": {"enum": ["none", "low", "medium", "high", "xhigh", "max"]},
        "evidence": {"type": "string", "minLength": 1}
      }
    },
    "runtime_capabilities": {
      "type": "object",
      "additionalProperties": false,
      "required": ["custom_agent", "model_override", "available_agents", "available_models"],
      "properties": {
        "custom_agent": {"type": "boolean"},
        "model_override": {"type": "boolean"},
        "available_agents": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "available_models": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}}
      }
    }
  }
}
