{
  "$schema": "https://json-schema.org/draft/2020-12/schema", "$id": "https://openai.com/codex/gpt56-router/child-event.schema.json",
  "title": "GPT-5.6 router child event", "type": "object",
  "required": ["schema_version", "event_type", "task_id", "node_id", "agent_path", "summary", "outcomes", "discovered_work", "validation", "blockers", "questions", "risks", "write_scopes", "review"],
  "properties": {
    "schema_version": {"const": 1},
    "event_type": {"enum": ["progress", "complete", "partial", "new_work", "needs_decision", "approval_required", "risk_discovered", "validation_failed", "blocked", "conflict", "budget_exhausted", "cancelled", "failed"]},
    "task_id": {"type": "string", "minLength": 1},
    "node_id": {"type": "string", "minLength": 1}, "agent_path": {"type": "string", "minLength": 1},
    "summary": {"type": "string"}, "outcomes": {"type": "array"}, "discovered_work": {"type": "array"}, "validation": {"type": "array"},
    "blockers": {"type": "array"}, "questions": {"type": "array"}, "risks": {"type": "array"}, "write_scopes": {"type": "array"},
    "review": {"type": "object", "required": ["required", "status", "findings"], "properties": {"required": {"type": "boolean"}, "status": {"enum": ["not_required", "pending", "passed", "failed"]}, "findings": {"type": "array"}}, "additionalProperties": false}
  }, "additionalProperties": false
}
