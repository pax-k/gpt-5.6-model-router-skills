{
  "$schema": "https://json-schema.org/draft/2020-12/schema", "$id": "https://openai.com/codex/gpt56-router/task-graph.schema.json",
  "title": "GPT-5.6 router task graph", "type": "object",
  "required": ["schema_version", "root_task_id", "authority_envelope", "budgets", "nodes", "outstanding_human_decisions", "external_blockers", "remaining_review"],
  "properties": {
    "schema_version": {"const": 1}, "root_task_id": {"type": "string", "minLength": 1}, "authority_envelope": {"type": "object"},
    "budgets": {"type": "object", "required": ["max_depth", "max_open_threads", "max_total_spawns", "max_children_per_node", "max_parallel_children"], "properties": {"max_depth": {"type": "integer", "minimum": 0}, "max_open_threads": {"type": "integer", "minimum": 0}, "max_total_spawns": {"type": "integer", "minimum": 0}, "max_children_per_node": {"type": "integer", "minimum": 0}, "max_parallel_children": {"type": "integer", "minimum": 0}}, "additionalProperties": false},
    "nodes": {"type": "array", "items": {"type": "object", "required": ["task_id", "status", "dependencies", "route_history", "required_review"], "properties": {"task_id": {"type": "string", "minLength": 1}, "status": {"enum": ["queued", "ready", "running", "waiting", "blocked", "review", "repair", "complete", "partial", "failed", "cancelled"]}, "dependencies": {"$ref": "#/$defs/strings"}, "route_history": {"$ref": "#/$defs/strings"}, "required_review": {"type": "boolean"}}, "additionalProperties": false}},
    "outstanding_human_decisions": {"type": "array"}, "external_blockers": {"type": "array"}, "remaining_review": {"type": "array"}
  }, "$defs": {"strings": {"type": "array", "items": {"type": "string", "minLength": 1}}}, "additionalProperties": false
}
