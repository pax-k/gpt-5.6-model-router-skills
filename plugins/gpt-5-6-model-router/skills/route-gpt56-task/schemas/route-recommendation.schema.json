{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://paxdynamics.com/schemas/gpt56-router/route-recommendation-v3.json",
  "title": "GPT-5.6 Route Recommendation v3",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "preferred_route", "availability", "review", "reason_codes"],
  "properties": {
    "schema_version": {"const": 3},
    "preferred_route": {"$ref": "#/$defs/route"},
    "availability": {"enum": ["custom_agent", "model_override", "unavailable", "unknown"]},
    "review": {
      "type": "object",
      "additionalProperties": false,
      "required": ["recommended", "preferred_reviewer"],
      "properties": {
        "recommended": {"type": "boolean"},
        "preferred_reviewer": {"anyOf": [{"$ref": "#/$defs/route"}, {"type": "null"}]}
      }
    },
    "reason_codes": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}}
  },
  "$defs": {
    "route": {
      "type": "object",
      "additionalProperties": false,
      "required": ["agent", "model", "reasoning_effort", "read_only"],
      "properties": {
        "agent": {"type": "string", "minLength": 1},
        "model": {"type": "string", "minLength": 1},
        "reasoning_effort": {"enum": ["none", "low", "medium", "high", "xhigh", "max"]},
        "read_only": {"type": "boolean"}
      }
    }
  }
}
