{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://paxdynamics.com/schemas/gpt56-router/route-recommendation-v4.json",
  "title": "GPT-5.6 Route Recommendation v4",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "profile_sha256", "preferred_route", "availability", "constraints", "review", "reason_codes"],
  "properties": {
    "schema_version": {"const": 4},
    "profile_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "preferred_route": {"$ref": "#/$defs/route"},
    "availability": {"enum": ["custom_agent", "model_override", "unavailable", "unknown"]},
    "constraints": {
      "type": "object",
      "additionalProperties": false,
      "required": ["critical", "minimum_model", "minimum_effort"],
      "properties": {
        "critical": {"type": "boolean"},
        "minimum_model": {"type": ["string", "null"]},
        "minimum_effort": {"enum": ["medium", null]}
      }
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required", "preferred_reviewer"],
      "properties": {
        "required": {"type": "boolean"},
        "preferred_reviewer": {"anyOf": [{"$ref": "#/$defs/route"}, {"type": "null"}]}
      }
    },
    "reason_codes": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}}
  },
  "$defs": {
    "route": {
      "type": "object",
      "additionalProperties": false,
      "required": ["agent", "model", "reasoning_effort", "read_only"],
      "properties": {
        "agent": {"type": "string", "minLength": 1},
        "model": {"type": "string", "minLength": 1},
        "reasoning_effort": {"enum": ["none", "low", "medium", "high", "xhigh", "max"]},
        "read_only": {"type": "boolean"}
      }
    }
  }
}
