{
  "$schema": "https://json-schema.org/draft/2020-12/schema", "$id": "https://openai.com/codex/gpt56-router/delegation-capability.schema.json",
  "title": "GPT-5.6 router delegation capability", "type": "object",
  "required": ["schema_version", "allowed", "remaining_depth", "max_children", "max_parallel_children", "allowed_roles", "allowed_models", "allowed_write_scopes", "may_spawn_writers", "forbidden_actions", "required_return"],
  "properties": {
    "schema_version": {"const": 1}, "allowed": {"type": "boolean"}, "remaining_depth": {"type": "integer", "minimum": 0, "maximum": 2},
    "max_children": {"type": "integer", "minimum": 0, "maximum": 3}, "max_parallel_children": {"type": "integer", "minimum": 0, "maximum": 2},
    "allowed_roles": {"$ref": "#/$defs/strings"}, "allowed_models": {"$ref": "#/$defs/strings"}, "allowed_write_scopes": {"$ref": "#/$defs/strings"},
    "may_spawn_writers": {"type": "boolean"}, "forbidden_actions": {"$ref": "#/$defs/strings"}, "required_return": {"$ref": "#/$defs/strings"}
  },
  "$defs": {"strings": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}}}, "additionalProperties": false
}
