{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openai.com/codex/gpt56-router/route-decision.schema.json",
  "title": "GPT-5.6 router route decision",
  "type": "object",
  "required": ["schema_version", "decision", "routing_mode", "primary", "review", "advisory", "delegation_capability", "parallel_eligibility", "reason_codes"],
  "properties": {
    "schema_version": {"const": 1}, "task_id": {"type": "string", "minLength": 1}, "node_id": {"type": "string", "minLength": 1},
    "decision": {"enum": ["direct_execution", "delegate", "ask_human", "wait", "unsupported"]},
    "routing_mode": {"enum": ["custom_agent", "model_override", "unsupported", "direct"]},
    "primary": {"oneOf": [{"$ref": "#/$defs/route"}, {"type": "null"}]},
    "review": {"$ref": "#/$defs/conditional_route"},
    "advisory": {"$ref": "#/$defs/conditional_route"},
    "delegation_capability": {"$ref": "#/$defs/delegation_capability"},
    "parallel_eligibility": {"$ref": "#/$defs/parallel_eligibility"},
    "reason_codes": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "pattern": "^[A-Z][A-Z0-9_]*$"}}
  },
  "$defs": {
    "effort": {"enum": ["none", "low", "medium", "high", "xhigh", "max"]},
    "route": {"type": "object", "required": ["agent", "model", "reasoning_effort", "read_only"], "properties": {"agent": {"type": "string", "minLength": 1}, "model": {"type": "string", "minLength": 1}, "reasoning_effort": {"$ref": "#/$defs/effort"}, "read_only": {"type": "boolean"}}, "additionalProperties": false},
    "conditional_route": {"type": "object", "required": ["required", "route"], "properties": {"required": {"type": "boolean"}, "route": {"oneOf": [{"$ref": "#/$defs/route"}, {"type": "null"}]}}, "additionalProperties": false},
    "strings": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "delegation_capability": {"type": "object", "required": ["schema_version", "allowed", "remaining_depth", "max_children", "max_parallel_children", "allowed_roles", "allowed_models", "allowed_write_scopes", "may_spawn_writers", "forbidden_actions", "required_return"], "properties": {"schema_version": {"const": 1}, "allowed": {"type": "boolean"}, "remaining_depth": {"type": "integer", "minimum": 0, "maximum": 2}, "max_children": {"type": "integer", "minimum": 0, "maximum": 3}, "max_parallel_children": {"type": "integer", "minimum": 0, "maximum": 2}, "allowed_roles": {"$ref": "#/$defs/strings"}, "allowed_models": {"$ref": "#/$defs/strings"}, "allowed_write_scopes": {"$ref": "#/$defs/strings"}, "may_spawn_writers": {"type": "boolean"}, "forbidden_actions": {"$ref": "#/$defs/strings"}, "required_return": {"$ref": "#/$defs/strings"}}, "additionalProperties": false},
    "parallel_eligibility": {"type": "object", "required": ["eligible", "requires_disjoint_peers", "reason_code"], "properties": {"eligible": {"type": "boolean"}, "requires_disjoint_peers": {"type": "boolean"}, "reason_code": {"type": "string", "pattern": "^[A-Z][A-Z0-9_]*$"}}, "additionalProperties": false}
  },
  "additionalProperties": false
}
